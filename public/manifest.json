{
  "manifest_version": 3,
  "name": "Firefox Custom Elements",
  "version": "1.0",
  "description": "Custom elements dev tools for firefox that do not break",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "assets/background.js",
    "scripts": ["assets/background.js"],
    "type": "module"
  },
  "host_permissions": [
    "*://*/*"
  ],
  "devtools_page": "devtools.html"
}
